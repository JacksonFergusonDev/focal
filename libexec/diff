#!/usr/bin/env bash
set -euo pipefail

# DESC: Copies a formatted git diff of uncommitted or staged changes.

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
source "${SCRIPT_DIR}/../lib/core.sh"

require_cmd "git"

# Default git diff arguments
diff_args=("-M")
target_name="working tree"

# Parse basic flags
if [ "${1:-}" == "--staged" ] || [ "${1:-}" == "--cached" ]; then
  diff_args+=("--staged")
  target_name="staged changes"
  shift
fi

# Pass any remaining arguments (like specific files) to git diff
if [ $# -gt 0 ]; then
  diff_args+=("--" "$@")
  target_name="specified files"
fi

# Execute diff
diff_output=$(git diff "${diff_args[@]}")

if [ -z "$diff_output" ]; then
  echo "No changes detected in $target_name."
  exit 0
fi

# Wrap in markdown diff block
buffer="\`\`\`diff\n${diff_output}\n\`\`\`"

output_and_copy "$buffer" "Copied diff of $target_name"
